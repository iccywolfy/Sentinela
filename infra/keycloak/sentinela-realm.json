{
  "realm": "sentinela",
  "enabled": true,
  "displayName": "SENTINELA",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "sentinela-api",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "sentinela-api-secret",
      "redirectUris": ["http://localhost:3000/*", "http://localhost:5173/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:5173"],
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "sentinela-frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "standardFlowEnabled": true,
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin", "description": "Platform administrator" },
      { "name": "senior_analyst", "description": "Senior intelligence analyst" },
      { "name": "analyst", "description": "Intelligence analyst" },
      { "name": "viewer", "description": "Read-only access" }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@sentinela.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "sentinela", "temporary": false }],
      "realmRoles": ["admin"]
    },
    {
      "username": "analyst",
      "email": "analyst@sentinela.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "sentinela", "temporary": false }],
      "realmRoles": ["analyst"]
    }
  ]
}
