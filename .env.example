# ─────────────────────────────────────────────────────────────
# SENTINELA — Environment Variables
# Copy to .env and fill in values before running
# ─────────────────────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql://sentinela:sentinela@localhost:5432/sentinela

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=sentinela

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=sentinela-group

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sentinela

# Auth (Keycloak)
AUTH_KEYCLOAK_URL=http://localhost:8080
AUTH_KEYCLOAK_REALM=sentinela
AUTH_KEYCLOAK_CLIENT_ID=sentinela-api
AUTH_KEYCLOAK_CLIENT_SECRET=change-me
JWT_SECRET=super-secret-jwt-key-change-in-production

# Services (internal)
INGESTION_SERVICE_URL=http://localhost:3001
CORRELATION_SERVICE_URL=http://localhost:3002
ALERT_SERVICE_URL=http://localhost:3003
NLP_SERVICE_URL=http://localhost:8000
REPORT_SERVICE_URL=http://localhost:3004
API_GATEWAY_URL=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:3000
VITE_MAPBOX_TOKEN=your-mapbox-token-here

# NLP Service
NLP_MODEL_PATH=/models
TRANSLATION_MODEL=Helsinki-NLP/opus-mt-en-ROMANCE
NER_MODEL=en_core_web_trf

# Reporting
CHROMIUM_PATH=/usr/bin/chromium

# Multi-tenancy
DEFAULT_TENANT_ID=default

# Feature flags
ENABLE_AI_ASSISTANT=false
ENABLE_VECTOR_SEARCH=false
