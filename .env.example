# ═══════════════════════════════════════════════════════════════════════════════
# SENTINELA — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://sentinela:CHANGE_ME@postgres:5432/sentinela
POSTGRES_PASSWORD=CHANGE_ME  # Generate: openssl rand -base64 24

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate secure secrets: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_chars_use_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_different_from_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=8h

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://app.sentinela.io

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTIC_PASSWORD=CHANGE_ME  # Generate: openssl rand -base64 24

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME  # Generate: openssl rand -base64 32
S3_BUCKET=sentinela

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── Keycloak (SSO) ────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=sentinela_admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME  # Generate: openssl rand -base64 24
AUTH_KEYCLOAK_URL=http://keycloak:8080
AUTH_KEYCLOAK_REALM=sentinela
AUTH_KEYCLOAK_CLIENT_ID=sentinela-api

# ── NLP Service ───────────────────────────────────────────────────────────────
NLP_SERVICE_URL=http://nlp-service:8000
NLP_API_KEY=CHANGE_ME  # Generate: openssl rand -base64 32

# ── Internal Service Auth ─────────────────────────────────────────────────────
# Shared token for service-to-service calls (api-gateway → internal services)
SERVICE_TOKEN=CHANGE_ME  # Generate: openssl rand -base64 32

# ── Service URLs (internal) ───────────────────────────────────────────────────
INGESTION_SERVICE_URL=http://ingestion-service:3001
CORRELATION_SERVICE_URL=http://correlation-service:3002
ALERT_SERVICE_URL=http://alert-service:3003
REPORT_SERVICE_URL=http://report-service:3004

# ── Ports ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@sentinela.io
